# Copy to .env and adjust for your environment. These are read by Django
# settings (config/settings.py). All are optional for local dev — sensible
# fallbacks apply — but DJANGO_SECRET_KEY MUST be set in any deployed
# environment. Never commit a filled-in .env (it is gitignored).
#
# The React frontend needs no env vars locally: Vite proxies /api to the
# Django backend (see frontend/vite.config.ts).

# Enable Django debug mode (verbose errors, relaxed host checks).
# Off unless set to exactly "1".
DJANGO_DEBUG=1

# Secret key for cryptographic signing. REQUIRED in production. Left blank so
# local dev falls back to a random per-process key; generate a real one with:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=

# Comma-separated hostnames Django will serve. Defaults to loopback only.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Postgres connection URL. Unset = SQLite (db.sqlite3) for local dev/tests.
# DATABASE_URL=postgresql://app:app@localhost:5432/app
